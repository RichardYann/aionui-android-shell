<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <gradient
        android:angle="270"
        android:startColor="#09101A"
        android:centerColor="#0C1523"
        android:endColor="#050810" />
    </shape>
  </item>

  <item
    android:width="320dp"
    android:height="320dp"
    android:gravity="top|end"
    android:right="-64dp"
    android:top="-40dp">
    <shape android:shape="oval">
      <gradient
        android:type="radial"
        android:centerColor="#4439D6FF"
        android:endColor="#0039D6FF"
        android:gradientRadius="180dp" />
    </shape>
  </item>

  <item
    android:width="260dp"
    android:height="260dp"
    android:gravity="bottom|start"
    android:bottom="-60dp"
    android:left="-48dp">
    <shape android:shape="oval">
      <gradient
        android:type="radial"
        android:centerColor="#2227FFC3"
        android:endColor="#0027FFC3"
        android:gradientRadius="150dp" />
    </shape>
  </item>
</layer-list>
