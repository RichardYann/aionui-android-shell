<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/dialog_switcher_background"
  android:orientation="vertical"
  android:padding="20dp">

  <TextView
    android:id="@+id/switcherTitle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="@string/server_dialog_title"
    android:textColor="#FFFFFFFF"
    android:textSize="20sp"
    android:textStyle="bold" />

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:fillViewport="true">

    <LinearLayout
      android:id="@+id/switcherServerList"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical" />
  </ScrollView>

  <Button
    android:id="@+id/switcherManageAction"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="16dp"
    android:background="@drawable/nav_change_server_button"
    android:text="@string/server_add_new"
    android:textAllCaps="false"
    android:textColor="#F3FAFF"
    android:textStyle="bold" />
</LinearLayout>
