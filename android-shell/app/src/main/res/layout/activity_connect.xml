<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/connect_screen_background">

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <LinearLayout
        android:id="@+id/connectCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/connect_glass_card"
        android:orientation="vertical">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/connect_card_title"
          android:textColor="#FFFFFFFF"
          android:textSize="20sp"
          android:textStyle="bold" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="@string/connect_card_subtitle"
          android:textColor="#B7D2E8"
          android:textSize="14sp" />

        <EditText
          android:id="@+id/nameInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="18dp"
          android:background="@drawable/connect_input_background"
          android:hint="@string/connect_name_hint"
          android:inputType="textPersonName"
          android:singleLine="true"
          android:textColor="#FFFFFFFF"
          android:textColorHint="#7EA0BA" />

        <EditText
          android:id="@+id/urlInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="12dp"
          android:background="@drawable/connect_input_background"
          android:hint="@string/connect_url_hint"
          android:inputType="textUri"
          android:singleLine="true"
          android:textColor="#FFFFFFFF"
          android:textColorHint="#7EA0BA" />

        <Button
          android:id="@+id/connectButton"
          android:layout_width="match_parent"
          android:layout_height="52dp"
          android:layout_marginTop="18dp"
          android:background="@drawable/connect_primary_button"
          android:text="@string/connect_button"
          android:textAllCaps="false"
          android:textColor="#FFFFFFFF"
          android:textStyle="bold" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/savedServersSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/connect_glass_card"
        android:orientation="vertical">

        <TextView
          android:id="@+id/savedServersTitle"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/connect_saved_servers"
          android:textColor="#FFFFFFFF"
          android:textSize="18sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/savedServersSubtitle"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="@string/connect_saved_servers_subtitle"
          android:textColor="#B7D2E8"
          android:textSize="13sp" />

        <LinearLayout
          android:id="@+id/serverListContainer"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="16dp"
          android:orientation="vertical" />
      </LinearLayout>
    </LinearLayout>
  </ScrollView>
</FrameLayout>
